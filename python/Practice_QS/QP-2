def generate_random_graph(n=10):
    graph = {}
    for i in range(n):
        graph[i] = random.sample(range(n), random.randint(1, n-1))
    return graph

def dfs(graph, start, visited=None):
    if visited is None:
        visited = set()
    visited.add(start)
    for node in graph[start]:
        if node not in visited:
            dfs(graph, node, visited)
    return visited

# -----------------------------
# MAIN
# -----------------------------

if __name__ == "__main__":
    app = App()
    app.run()