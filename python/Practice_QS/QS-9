# -----------------------------
# UTILITIES
# -----------------------------

def current_time():
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")

def random_name():
    first = [
        "Amit", "Rahul", "Sneha", "Priya",
        "Rohan", "Karan", "Anjali", "Vikas"
    ]

    last = [
        "Sharma", "Patil", "Mehta",
        "Joshi", "Kulkarni", "Singh"
    ]

    return random.choice(first) + " " + random.choice(last)

# -----------------------------
# PATIENT SYSTEM
# -----------------------------

class Patient:

    def __init__(self, pid):

        self.id = pid
        self.name = random_name()
        self.age = random.randint(1, 90)

        self.temperature = round(
            random.uniform(96, 104), 2
        )

        self.heart_rate = random.randint(60, 150)

        self.bp = (
            random.randint(90, 160),
            random.randint(60, 100)
        )

        self.condition = random.choice([
            "Normal",
            "Critical",
            "Stable",
            "Observation"
        ])

        self.room = random.randint(100, 500)

    def update(self):

        self.temperature += random.uniform(-1, 1)
        self.heart_rate += random.randint(-5, 5)

# -----------------------------
# DOCTOR SYSTEM
# -----------------------------

class Doctor:

    def __init__(self, did):

        self.id = did
        self.name = random_name()

        self.specialization = random.choice([
            "Cardiology",
            "Neurology",
            "Orthopedics",
            "Pediatrics",
            "Radiology"
        ])

        self.experience = random.randint(1, 30)

    def diagnose(self, patient):

        if patient.temperature > 101:
            return "Infection"

        if patient.heart_rate > 120:
            return "Cardiac Issue"

        return "Normal"

# -----------------------------
# NURSE SYSTEM
# -----------------------------

class Nurse:

    def __init__(self, nid):

        self.id = nid
        self.name = random_name()

    def assist(self, patient):

        patient.condition = "Stable"

# -----------------------------
# MEDICINE INVENTORY
# -----------------------------

class Medicine:

    def __init__(self, name):

        self.name = name
        self.stock = random.randint(50, 500)

    def use(self, qty):

        if self.stock >= qty:
            self.stock -= qty

# -----------------------------
# LAB TEST SYSTEM
# -----------------------------

class LabTest:

    def __init__(self):

        self.tests = [
            "Blood Test",
            "MRI",
            "CT Scan",
            "X-Ray",
            "ECG"
        ]

    def perform(self):

        return {
            "test": random.choice(self.tests),
            "result": random.choice([
