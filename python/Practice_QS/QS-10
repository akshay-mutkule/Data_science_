import random
import string
import math
from datetime import datetime

# ============================================================
# ADVANCED UNIVERSITY MANAGEMENT & AI LEARNING SYSTEM
# ============================================================

# -----------------------------
# UTILITY FUNCTIONS
# -----------------------------

def current_time():
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")

def random_name():

    first = [
        "Aman", "Rohit", "Priya",
        "Sneha", "Kunal", "Pooja",
        "Raj", "Vikas"
    ]

    last = [
        "Patil", "Sharma", "Joshi",
        "Kulkarni", "Singh", "Mehta"
    ]

    return random.choice(first) + " " + random.choice(last)

def random_subject():

    return random.choice([
        "Artificial Intelligence",
        "Machine Learning",
        "Data Structures",
        "Cloud Computing",
        "Cyber Security",
        "Blockchain"
    ])

# -----------------------------
# STUDENT SYSTEM
# -----------------------------

class Student:

    def __init__(self, sid):

        self.id = sid
        self.name = random_name()
        self.age = random.randint(18, 30)

        self.attendance = random.randint(50, 100)

        self.marks = {
            random_subject(): random.randint(40, 100)
            for _ in range(4)
        }

        self.cgpa = round(
            random.uniform(5.0, 10.0), 2
        )

    def update_attendance(self):

        self.attendance += random.randint(-2, 2)

        self.attendance = max(
            0,
            min(100, self.attendance)
        )

    def average_marks(self):

        return (
            sum(self.marks.values())
            / len(self.marks)
        )

# -----------------------------
# PROFESSOR SYSTEM
# -----------------------------

class Professor:

    def __init__(self, pid):

        self.id = pid
        self.name = random_name()
        self.subject = random_subject()

        self.experience = random.randint(1, 35)

    def evaluate(self, student):

        avg = student.average_marks()

        if avg > 85:
            return "Excellent"

        elif avg > 70:
            return "Good"

        elif avg > 50:
            return "Average"

        return "Poor"

# -----------------------------
# COURSE SYSTEM
# -----------------------------

class Course:

    def __init__(self, cid):

        self.id = cid
        self.name = random_subject()
        self.credits = random.randint(2, 5)

        self.students = []

    def enroll(self, student):

        self.students.append(student)

# -----------------------------
# LIBRARY SYSTEM
# -----------------------------

class Book:

    def __init__(self):

        self.title = ''.join(
            random.choice(string.ascii_uppercase)
            for _ in range(6)
        )

        self.available = True

class Library:

    def __init__(self):

        self.books = [
            Book() for _ in range(100)
        ]

    def issue_book(self):

        available_books = [
            b for b in self.books
            if b.available
        ]

        if available_books:

            book = random.choice(available_books)
            book.available = False

            return book.title

# -----------------------------
# HOSTEL SYSTEM
# -----------------------------

class Hostel:

    def __init__(self):

        self.rooms = {
            i: None for i in range(1, 101)
        }

    def allocate(self, student):

        for room in self.rooms:

            if self.rooms[room] is None:

                self.rooms[room] = student.name
                return room

# -----------------------------
# EXAMINATION SYSTEM
# -----------------------------

class Examination:

    def conduct_exam(self, student):

        result = {}

        for subject in student.marks:

            score = random.randint(35, 100)
            result[subject] = score

        return result

# -----------------------------
# AI LEARNING ANALYTICS
# -----------------------------

class LearningAI:

    def performance_prediction(self, student):

        score = (
            student.average_marks()
            + student.attendance
        ) / 2

        if score > 85:
            return "TOPPER"

        elif score > 70:
            return "ABOVE AVERAGE"

        elif score > 50:
            return "AVERAGE"

        return "AT RISK"

