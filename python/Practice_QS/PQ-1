class SimpleModel:
    def __init__(self):
        self.weights = [random.random() for _ in range(5)]

    def predict(self, features):
        return sum(w*f for w, f in zip(self.weights, features))

    def train(self):
        for _ in range(100):
            self.weights = [w + random.uniform(-0.1, 0.1) for w in self.weights]

