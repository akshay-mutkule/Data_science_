# CYBER SIMULATION
# -----------------------------

class CyberSimulation:

    def __init__(self):

        self.users = [User(i) for i in range(20)]

        self.firewall = Firewall()
        self.ids = IDS()
        self.soc = SOC()

        self.servers = [
            Server(i) for i in range(5)
        ]

        self.ai = AIDefense(self.firewall)

        self.scanner = VulnerabilityScanner()

        self.logs = []

    def simulate_packet_flow(self):

        packet = Packet()

        self.ids.inspect(packet)
        self.ai.analyze(packet)

        self.logs.append(packet)

    def simulate_attack(self):

        server = random.choice(self.servers)

        attack = DDoSAttack()
        attack.attack(server)

        self.soc.log(
            f"DDoS attack on {server.ip}"
        )

    def simulate_malware(self):

        malware = Malware()
        server = random.choice(self.servers)

        malware.infect(server)

        self.soc.log(
            f"{malware.name} infected {server.ip}"
        )

    def update_servers(self):

        for server in self.servers:

            server.update_load()
            self.scanner.scan(server)

# -----------------------------
# ANALYTICS SYSTEM
# -----------------------------

class Analytics:

    @staticmethod
    def average_cpu(servers):

        return sum(
            s.cpu for s in servers
        ) / len(servers)

    @staticmethod
    def average_memory(servers):

        return sum(
            s.memory for s in servers
        ) / len(servers)

    @staticmethod
    def compromised_servers(servers):

        return [
            s.ip for s in servers
            if s.health < 50
        ]

# -----------------------------
# GRAPH SYSTEM
# -----------------------------

class NetworkGraph:

    def __init__(self, size=10):

        self.graph = {
            i: [] for i in range(size)
        }

        for i in range(size):

            for j in range(size):

                if i != j and random.random() > 0.5:
                    self.graph[i].append(j)

    def bfs(self, start):

        visited = set()
        queue = [start]

        while queue:

            node = queue.pop(0)

            if node not in visited:

                visited.add(node)

                for neighbor in self.graph[node]:
                    queue.append(neighbor)

        return visited

