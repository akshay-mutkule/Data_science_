import random
import string
import hashlib
import time
from datetime import datetime

# ============================================================
# CYBER SECURITY ATTACK & DEFENSE SIMULATOR
# ============================================================

# -----------------------------
# UTILITY FUNCTIONS
# -----------------------------

def random_ip():
    return ".".join(str(random.randint(1, 255)) for _ in range(4))

def random_username():
    return ''.join(random.choices(string.ascii_lowercase, k=8))

def random_password():
    chars = string.ascii_letters + string.digits
    return ''.join(random.choice(chars) for _ in range(12))

def current_time():
    return datetime.now().strftime("%Y-%m-%d %H:%M:%S")

# -----------------------------
# USER SYSTEM
# -----------------------------

class User:

    def __init__(self, uid):

        self.id = uid
        self.username = random_username()
        self.password = self.encrypt(random_password())
        self.role = random.choice([
            "Admin",
            "Analyst",
            "Guest",
            "Developer"
        ])

        self.failed_attempts = 0
        self.locked = False

    def encrypt(self, text):
        return hashlib.sha256(text.encode()).hexdigest()

    def login(self, password):

        if self.locked:
            return False

        if self.encrypt(password) == self.password:
            self.failed_attempts = 0
            return True

        self.failed_attempts += 1

        if self.failed_attempts >= 3:
            self.locked = True

        return False

# -----------------------------
# FIREWALL SYSTEM
# -----------------------------

class Firewall:

    def __init__(self):

        self.blocked_ips = set()
        self.rules = []

    def add_rule(self, rule):
        self.rules.append(rule)

    def block_ip(self, ip):
        self.blocked_ips.add(ip)

    def is_blocked(self, ip):
        return ip in self.blocked_ips

# -----------------------------
# NETWORK PACKET SYSTEM
# -----------------------------

class Packet:

    def __init__(self):

        self.source = random_ip()
        self.destination = random_ip()
        self.size = random.randint(64, 1500)
        self.protocol = random.choice([
            "TCP",
            "UDP",
            "HTTP",
            "HTTPS"
        ])

# -----------------------------
# INTRUSION DETECTION SYSTEM
# -----------------------------

class IDS:

    def __init__(self):

        self.alerts = []

    def inspect(self, packet):

        suspicious = False

        if packet.size > 1400:
            suspicious = True

        if packet.protocol == "HTTP":
            suspicious = True

        if suspicious:

            alert = {
                "time": current_time(),
                "source": packet.source,
                "protocol": packet.protocol,
                "size": packet.size
            }

            self.alerts.append(alert)

# -----------------------------
# MALWARE SYSTEM
# -----------------------------

class Malware:

    def __init__(self):

        self.name = random.choice([
            "Trojan",
            "Ransomware",
            "Spyware",
            "Rootkit"
        ])

        self.severity = random.randint(1, 10)

    def infect(self, system):

        damage = random.randint(10, 50)
        system.health -= damage

# -----------------------------
# SERVER SYSTEM
# -----------------------------

class Server:

    def __init__(self, sid):

        self.id = sid
        self.ip = random_ip()
        self.health = 100
        self.cpu = random.randint(10, 40)
        self.memory = random.randint(20, 60)

    def update_load(self):

        self.cpu += random.randint(-5, 10)
        self.memory += random.randint(-5, 10)

        self.cpu = max(0, min(100, self.cpu))
        self.memory = max(0, min(100, self.memory))

# -----------------------------
# DDOS ATTACK SYSTEM
# -----------------------------

class DDoSAttack:

    def __init__(self):

        self.bot_count = random.randint(100, 5000)

    def attack(self, server):

        impact = self.bot_count // 100
        server.cpu += impact

        if server.cpu > 100:
            server.cpu = 100

