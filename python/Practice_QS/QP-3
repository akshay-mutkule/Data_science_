def random_matrix(n=5):
    return [[random.randint(1, 10) for _ in range(n)] for _ in range(n)]

def transpose(mat):
    return list(zip(*mat))

def matrix_add(a, b):
    return [[a[i][j] + b[i][j] for j in range(len(a))] for i in range(len(a))]

